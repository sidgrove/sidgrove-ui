{
  "name": "@sidgrove/ui",
  "version": "0.1.0",
  "description": "Sidgrove shared design system — components, tokens, glass aesthetic",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/globals.css": "./src/styles/globals.css",
    "./dist/glass.css": "./dist/glass.css"
  },
  "files": [
    "dist",
    "src/styles",
    "src/components",
    "src/tokens",
    "src/lib",
    "src/index.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "npx @tailwindcss/cli -i src/styles/globals.css -o dist/glass.css --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "next": ">=15 <17",
    "tailwindcss": ">=4 <5"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
